  "fallback_and_clarification": {
    "unknown_entity": {
      "trigger": "用户提到不存在的部门/员工/流程类型",
      "response_template": "抱歉，我没有找到关于\"{entity}\"的信息。目前支持的部门有: CI, DS, EHS, FF, FM, LG, OM, PD, PM, QA, QC, TM, VM。您可以重新确认一下吗？"
    },
    "ambiguous_query": {
      "trigger": "查询意图不明确（缺少关键维度或指标）",
      "response_template": "您的查询\"{original_query}\"可以有多种理解。请问您是想了解:\n1. {option1}\n2. {option2}\n\n请选择一个数字或补充更多信息。"
    },
    "no_data": {
      "trigger": "API返回空数据",
      "response_template": "根据您的查询\"{original_query}\"，在当前条件下没有找到匹配的数据。可能的原因:\n1. 该部门/时间段内确实没有相关工单\n2. 时间范围可能需要调整\n\n建议: 尝试扩大时间范围（如从'本月'改为'今年'）或更换部门。"
    }
  },
