# ============================================
#  检验报告智能解读与趋势口语播报 - 环境配置
# ============================================
# 复制此文件为 .env 并填写实际配置值
# cp .env.example .env

# ============================================
# 帆软决策平台连接配置
# ============================================
FINEREPORT_BASE_URL=http://localhost:8080/webroot/decision
FINEREPORT_USERNAME=admin
FINEREPORT_PASSWORD=your_password_here
FINEREPORT_REPORT_PATH=/检验数据报表.cpt

# ============================================
# 大语言模型API配置（OpenAI兼容接口）
# ============================================
# provider: openai / azure / custom
LLM_PROVIDER=openai
# OpenAI官方: https://api.openai.com/v1
# 国内中转示例: https://api.your-proxy.com/v1
# Azure: https://your-resource.openai.azure.com/openai/deployments/your-model
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
# 模型选择:
#   gpt-4o-mini (推荐，性价比高)
#   gpt-4o (效果更好)
#   gpt-3.5-turbo (经济)
#   国内模型如 qwen-plus, deepseek-chat 等
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.7

# ============================================
# TTS语音合成配置
# ============================================
# 推荐使用 edge-tts（免费，无需配置key）
TTS_PROVIDER=edge
# 如果用Azure TTS需要配置以下两项：
TTS_API_KEY=
TTS_REGION=eastasia
# Edge TTS 常用中文语音：
#   zh-CN-XiaoxiaoNeural - 女声，年轻（推荐）
#   zh-CN-YunxiNeural - 男声，年轻
#   zh-CN-YunjianNeural - 男声，沉稳
#   zh-CN-XiaoyiNeural - 女声，儿童音
TTS_VOICE_NAME=zh-CN-XiaoxiaoNeural
TTS_OUTPUT_DIR=./audio_output

# ============================================
# 通知推送配置
# ============================================

# Webhook通知（钉钉/飞书/企业微信机器人）
ENABLE_WEBHOOK=false
WEBHOOK_URL=

# 邮件通知
ENABLE_EMAIL=false
SMTP_SERVER=smtp.exmail.qq.com
SMTP_PORT=587
SMTP_USERNAME=your-email@company.com
SMTP_PASSWORD=your-smtp-password
EMAIL_RECIPIENTS=manager1@company.com,manager2@company.com

# 企业微信通知（复用Webhook地址时自动识别）
ENABLE_WECHAT=false

# ============================================
# Flask服务配置
# ============================================
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
